# ========================
# KOMERCIJALA APP - /komercijala/
# Dodati u postojeci nginx server blok na karpas.app
# ========================

location = /komercijala {
    return 301 /komercijala/;
}

location /komercijala/api/ {
    proxy_pass http://localhost:3001/api/;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection 'upgrade';
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_cache_bypass $http_upgrade;
}

location /komercijala/ {
    alias /home/korisnik/KOMERCIJALA_WEB/dist/;
    index index.html;
    try_files $uri $uri/ @komercijala;
}

location @komercijala {
    rewrite ^/komercijala/(.*)$ /komercijala/index.html last;
    root /home/korisnik/KOMERCIJALA_WEB/dist;
}
